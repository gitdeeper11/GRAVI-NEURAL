# GRAVI-NEURAL Environment Variables Example
# Covariant Neural Characterization of Metric Tensor Perturbations

# ============= GRAVI-NEURAL Parameters =============
GRAVI_NEURAL_GNO=0.35
GRAVI_NEURAL_STCN=0.35
GRAVI_NEURAL_MGAN=0.30

# ============= Network Weights =============
GNO_W1_FNO=0.35
GNO_W2_BLOCK=0.35
GNO_W3_PROJECT=0.30

# ============= AI Architecture =============
GRAVI_NEURAL_FNO_EPOCHS=300
GRAVI_NEURAL_LATENT_DIM=256
GRAVI_NEURAL_FOURIER_MODES=16
GRAVI_NEURAL_PINN_STRENGTH=0.95

# ============= Physical Settings =============
GRAVI_NEURAL_SPACETIME_DIM=4
GRAVI_NEURAL_EFE_THRESHOLD=0.01
GRAVI_NEURAL_MAX_ITERATIONS=12
GRAVI_NEURAL_ENVIRONMENT=schwarzschild

# ============= Alert Thresholds =============
EFE_RESIDUAL_COLLAPSE=0.10
EFE_RESIDUAL_CRITICAL=0.05
EFE_RESIDUAL_MODERATE=0.02
EFE_RESIDUAL_GOOD=0.01
ALERT_LEAD_TIME_HOURS=48

# ============= Logging =============
GRAVI_NEURAL_LOG_LEVEL=INFO
GRAVI_NEURAL_SAVE_RESULTS=true
GRAVI_NEURAL_RESULTS_DIR=./results

# ============= API Keys (Optional) =============
# LIGO_DATA_API_KEY=your_key_here
# GRACE_FO_API_KEY=your_key_here
